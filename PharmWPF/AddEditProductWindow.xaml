<Window x:Class="PharmWPF.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PharmWPF"
        mc:Ignorable="d"
        Title="AddEditProductWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <ScrollViewer>
            <StackPanel Margin="20">

                <TextBlock Text="Название"/>
                <TextBox x:Name="ProductName"/>

                <TextBlock Text="Тип продукта"/>
                <ComboBox x:Name="ProductType"/>

                <TextBlock Text="Цена"/>
                <TextBox x:Name="ProductPrice"/>

                <TextBlock Text="Скидка (%)"/>
                <TextBox x:Name="ProductDiscount"/>

                <TextBlock Text="Активна ли скидка"/>
                <CheckBox x:Name="IsDiscountActive"/>

                <TextBlock Text="Количество на складе"/>
                <TextBox x:Name="ProductStockQuantity"/>

                <TextBlock Text="Минимальный остаток"/>
                <TextBox x:Name="ProductMinStock"/>

                <TextBlock Text="Описание"/>
                <TextBox x:Name="ProductDesc" Height="100" TextWrapping="Wrap"/>

                <TextBlock Text="Состав"/>
                <TextBox x:Name="ProductComposition" Height="100" TextWrapping="Wrap"/>

                <TextBlock Text="Фото (путь)"/>
                <TextBox x:Name="ProductPhoto"/>

            </StackPanel>
        </ScrollViewer>

        <Button x:Name="SaveButton"
            Grid.Row="1"
            Margin="20 0"
            Content="Сохранить"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Click="SaveButton_Click"/>

        <Button x:Name="CancelButton"
            Grid.Row="1"
            Margin="20 0"
            Content="Отменить"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="CancelButton_Click"/>

    </Grid>
</Window>
