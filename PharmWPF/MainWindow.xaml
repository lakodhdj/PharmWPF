<Window x:Class="PharmWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PharmWPF"
        mc:Ignorable="d"
        Icon="/Res/IconVe.ico"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image Source="/Res/IconVe.png" Margin="0,0,679,363"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Авторизация" Margin="40 10"/>
                <TextBox Name="LoginEnter" Margin="10" Height="25"/>
                <PasswordBox Name="PasswordEnter" Margin="10" Height="25"/>

                <Button x:Name="LoginButton" Content="Войти" Margin="40 10" Click="LoginButton_Click"/>
                <TextBlock HorizontalAlignment="Center" Text="Войти как гость" MouseDown="TextBlock_MouseDown" FontSize="13" Foreground="Blue"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
