<Window x:Class="PharmWPF.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Управление заказами" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Name="AdminPanelOrder" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20" Grid.Column="0">
                <TextBlock Text="Поиск (Адрес/Товар)"/>
                <TextBox Name="SearchingTextBox" TextChanged="FilterChanged" Width="200"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="1">
                <TextBlock Text="Сортировка по дате"/>
                <ComboBox Name="SortingComboBox" SelectionChanged="FilterChanged" Width="200"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="2">
                <TextBlock Text="Фильтрация (Статус)"/>
                <ComboBox Name="FilteringComboBox" SelectionChanged="FilterChanged" Width="200"/>
            </StackPanel>
        </Grid>

        <TextBlock Name="FullUserName" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20 10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="OrderList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Padding="10" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Tag="{Binding id}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="Bold" FontSize="14">
                                        <Run Text="Заказ №"/>
                                        <Run Text="{Binding id}"/>
                                        <Run Text=" от "/>
                                        <Run Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding Product.Name, StringFormat='Товар: {0}'}" Margin="0,5"/>

                                    <TextBlock TextWrapping="Wrap" Margin="0,2">
                                        <Run Text="Адрес доставки: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding DeliveryAddress}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Статус: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding OrderStatus.Name}" Foreground="DarkBlue"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding OrderTotal, StringFormat={}{0:N2} руб.}" FontSize="16" FontWeight="Bold" Foreground="Green"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat='Количество: {0} шт.'}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Назад" Name="BackButton" Click="BackButton_Click" Margin="20 0" Width="100" HorizontalAlignment="Left"/>
        <Button Grid.Row="2" Content="Создать заказ" Name="CreateButton" Click="CreateButton_Click" Margin="20 0" Width="120" HorizontalAlignment="Right" Visibility="Collapsed"/>
    </Grid>
</Window>